{
  "name": "smart-logistics-extractor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx --watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "db:seed": "tsx server/seed-cli.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "typecheck:root": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "quality": "node scripts/quality/pre-commit-check.js",
    "scan-secrets": "node scripts/quality/check-secrets.js",
    "test:integration": "node --import tsx --test shared/integrationConfig.test.ts services/integrationExportService.test.ts services/productMatchService.test.ts",
    "test:router": "node --import tsx --test server/services/documentExtractionService.router.test.ts",
    "check": "npm run typecheck && npm run format:check && npm run quality",
    "docker:up": "docker compose -f docker-compose.yml up -d --build",
    "docker:up:legacy": "docker compose -f docker-compose.yml -f docker-compose.legacy.yml up -d --build",
    "docker:up:genai-test": "docker compose -f docker-compose.yml -f docker-compose.genai-test.yml up -d --build",
    "docker:up:cache-test": "docker compose -f docker-compose.yml -f docker-compose.cache-test.yml up -d --build",
    "docker:up:legacy-cache-test": "docker compose -f docker-compose.yml -f docker-compose.legacy-cache-test.yml up -d --build",
    "docker:config": "docker compose -f docker-compose.yml config",
    "docker:config:genai-test": "docker compose -f docker-compose.yml -f docker-compose.genai-test.yml config",
    "docker:config:cache-test": "docker compose -f docker-compose.yml -f docker-compose.cache-test.yml config",
    "docker:down": "docker compose -f docker-compose.yml down"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.17.3",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.25",
    "lucide-react": "^0.344.0",
    "minio": "^8.0.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.35",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  }
}
