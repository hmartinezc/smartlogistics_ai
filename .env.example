# Puerto del servidor HTTP
PORT=3001

# Requerida para extraccion documental en backend
GEMINI_API_KEY=replace-with-real-key

# Opcion A: BD local persistida en volumen de Coolify
TURSO_DATABASE_URL=file:./data/smart-invoice.db

# Opcion B: Turso remoto
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=replace-with-real-token

# MinIO / S3-compatible storage para PDFs
# En Docker Compose, estas dos variables crean las credenciales internas de MinIO.
MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-minio-password

# En desarrollo fuera de Docker Compose, el backend puede conectarse a MinIO con estos valores.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-minio-user
MINIO_SECRET_KEY=replace-with-minio-password
MINIO_BUCKET=smart-invoices
MINIO_USE_SSL=false

# Tamaño máximo por PDF cargado (25 MB por defecto)
DOCUMENT_UPLOAD_MAX_BYTES=26214400

# Tamaño máximo total por request de carga (100 MB por defecto)
DOCUMENT_UPLOAD_MAX_TOTAL_BYTES=104857600

# Worker backend que procesa jobs QUEUED desde MinIO con Gemini
DOCUMENT_WORKER_ENABLED=true
DOCUMENT_WORKER_POLL_MS=5000
DOCUMENT_WORKER_CONCURRENCY=1
DOCUMENT_WORKER_STALE_PROCESSING_MS=1800000
