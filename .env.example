# Puerto del servidor HTTP
PORT=3001

# Requerida para extraccion documental en backend
GEMINI_API_KEY=replace-with-real-key
GEMINI_MODEL_ID=gemini-3-flash-preview
GEMINI_EXTRACTION_SDK=genai-router-files
GEMINI_EXTRACTION_PROMPT_PROFILE=full
GEMINI_EXTRACTION_FALLBACK_TO_LEGACY_ON_TRANSIENT_ERROR=false
GEMINI_GENERATE_TIMEOUT_MS=180000
GEMINI_CACHED_GENERATE_TIMEOUT_MS=180000
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_AI_REVIEW_MODEL_ID=gemini-3-flash-preview
GEMINI_ROUTER_MODEL_ID=gemini-3.1-flash-lite
GEMINI_ROUTER_EXTRACTOR_MODEL_ID=gemini-3-flash-preview
GEMINI_ROUTER_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
GEMINI_ROUTER_CLASSIFIER_MAX_OUTPUT_TOKENS=512
GEMINI_ROUTER_CLASSIFIER_MEDIA_RESOLUTION=medium
GEMINI_ROUTER_CLASSIFIER_THINKING_LEVEL=medium
GEMINI_ROUTER_CLASSIFIER_TIMEOUT_MS=45000
GEMINI_ROUTER_EXTRACTOR_TIMEOUT_MS=180000
GEMINI_THINKING_LEVEL=minimal
GEMINI_GENAI_TRANSIENT_RETRY_ATTEMPTS=3
GEMINI_GENAI_TRANSIENT_RETRY_BASE_DELAY_MS=15000
GEMINI_LEGACY_TRANSIENT_RETRY_ATTEMPTS=3
GEMINI_LEGACY_TRANSIENT_RETRY_BASE_DELAY_MS=15000

# Modo default sin cache: Files API + router + extractor especializado.
# Subir una vez a Gemini, clasificar, extraer y borrar el archivo remoto.
# Para comparar o hacer rollback rapido, cambia a GEMINI_EXTRACTION_SDK=legacy.

# Cache explicito del super prompt Gemini. Se mantiene disponible para diagnostico
# y pruebas controladas, pero no se usa en extraccion si GEMINI_PROMPT_CACHE_USE_FOR_EXTRACTION=false.
GEMINI_PROMPT_CACHE_ENABLED=true
GEMINI_PROMPT_CACHE_USE_FOR_EXTRACTION=false
GEMINI_PROMPT_CACHE_AUTO_WARM_ENABLED=false
GEMINI_PROMPT_CACHE_TRANSIENT_FALLBACK_TO_UNCACHED=false
GEMINI_PROMPT_CACHE_TTL_SECONDS=14400
GEMINI_PROMPT_CACHE_FAILURE_COOLDOWN_SECONDS=600
GEMINI_PROMPT_CACHE_CREATE_TIMEOUT_MS=60000

# Modo local para probar cache explicito. No usar como default de produccion.
# El fallback a legacy se deja solo para validaciones locales controladas.
# hasta comparar regresion contra PDFs reales.
# GEMINI_EXTRACTION_SDK=genai
# GEMINI_EXTRACTION_FALLBACK_TO_LEGACY_ON_TRANSIENT_ERROR=true
# GEMINI_PROMPT_CACHE_USE_FOR_EXTRACTION=true
# GEMINI_PROMPT_CACHE_AUTO_WARM_ENABLED=true
# GEMINI_PROMPT_CACHE_TRANSIENT_FALLBACK_TO_UNCACHED=true
# GEMINI_PROMPT_CACHE_TTL_SECONDS=900

# Variante experimental: SDK legacy + cachedContent explicito.
# Usa la misma cola y limite DOCUMENT_WORKER_CONCURRENCY, pero intenta cachear
# el prompt antes de caer a legacy directo si el cache falla.
# GEMINI_EXTRACTION_SDK=legacy-cache
# GEMINI_PROMPT_CACHE_USE_FOR_EXTRACTION=true
# GEMINI_PROMPT_CACHE_AUTO_WARM_ENABLED=false
# GEMINI_PROMPT_CACHE_TTL_SECONDS=900

# Fallback legacy: solo si no defines GEMINI_API_KEY
# API_KEY=replace-with-real-key

# Opcion A: BD local persistida en volumen de Coolify
TURSO_DATABASE_URL=file:./data/smart-invoice.db

# Opcion B: Turso remoto
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=replace-with-real-token

# MinIO / S3-compatible storage para PDFs
# En el Docker Compose del repo se mantienen credenciales internas fijas para MinIO.
# Estas variables quedan como referencia fuera de ese compose o si luego decides parametrizarlo.
MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-minio-password

# En desarrollo fuera de Docker Compose, el backend puede conectarse a MinIO con estos valores.
# En Docker Compose del repo, MINIO_ENDPOINT/MINIO_PORT/MINIO_ACCESS_KEY/MINIO_SECRET_KEY
# se inyectan automaticamente en el servicio app.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-minio-user
MINIO_SECRET_KEY=replace-with-minio-password
MINIO_BUCKET=smart-invoices
MINIO_USE_SSL=false

# Tamaño máximo por PDF cargado (25 MB por defecto)
DOCUMENT_UPLOAD_MAX_BYTES=26214400

# Tamaño máximo total por request de carga (100 MB por defecto)
DOCUMENT_UPLOAD_MAX_TOTAL_BYTES=104857600

# Worker backend que procesa jobs QUEUED desde MinIO con Gemini
DOCUMENT_WORKER_ENABLED=true
DOCUMENT_WORKER_POLL_MS=7000
DOCUMENT_WORKER_CONCURRENCY=5
DOCUMENT_WORKER_JOB_TIMEOUT_MS=300000
DOCUMENT_WORKER_STALE_PROCESSING_MS=2100000
