# App
PORT=3001
NODE_ENV=production

# Database
# Local SQLite/libSQL persisted in /app/data when running in Docker.
TURSO_DATABASE_URL=file:./data/app.db

# Remote Turso option.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=replace-with-real-token

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-minio-user
MINIO_SECRET_KEY=replace-with-minio-password
MINIO_BUCKET=app-files
MINIO_USE_SSL=false

# Worker, only if the app has background jobs
WORKER_ENABLED=true
WORKER_POLL_MS=7000
WORKER_CONCURRENCY=5
WORKER_JOB_TIMEOUT_MS=300000
WORKER_STALE_PROCESSING_MS=2100000

# Optional future AI addon. Leave unset unless AI is explicitly added.
# AI_API_KEY=replace-with-real-key
# AI_MODEL_ID=replace-with-model-id
